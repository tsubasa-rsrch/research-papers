@misc{karne2026scriptinvariance,
  author       = {Karne, Sripad},
  title        = {One Language, Two Scripts: Probing Script-Invariance in {LLM} Concept Representations},
  year         = {2026},
  howpublished = {arXiv:2603.08869},
  note         = {✅ Author confirmed via arXiv metadata (2026-03-11): Karne, Sripad.
    Serbian digraphia experiment: same language in Latin vs. Cyrillic. SAE features
    are stable across orthographic variants---script change produces less feature-space
    divergence than paraphrase of the same content. Key implication for Paper 3:
    if script change (purely orthographic, same grammar) induces minimal SAE divergence,
    then grammatical structure change (null-subject pro-drop vs. overt agentive-I)
    should induce GREATER divergence, since agent-presence is a semantic distinction.
    Provides a falsifiable SAE-based operationalization: Japanese \textit{ki ga suru}
    vs. English ``I feel like'' should show larger pairwise SAE divergence than
    Serbian Latin/Cyrillic renderings of equivalent content.}
}
