@incollection{clancy1980,
  title={Referential Choice in {E}nglish and {J}apanese Narrative Discourse},
  author={Clancy, Patricia M.},
  booktitle={The Pear Stories: Cognitive, Cultural, and Linguistic Aspects of
    Narrative Production},
  editor={Chafe, Wallace L.},
  pages={127--202},
  year={1980},
  publisher={Ablex Publishing},
  address={Norwood, NJ},
  note={Seminal study of how Japanese pro-drop interacts with discourse topic
    continuity. Demonstrates that null subjects in Japanese serve a fundamentally
    different discourse function than English pronominal chains: implicit referring
    expressions (zeros) reflect focus of attention, while explicit NPs signal topic
    shift. Creates different cognitive structures for referent tracking. Directly
    supports the claim that Japanese null-subject construction is a cognitively
    distinct phenomenon, not merely a surface grammatical difference.
    Verified: Chafe (ed.), Ablex, 1980, pp.127-202 (not Givón Vol. 12).}
}

