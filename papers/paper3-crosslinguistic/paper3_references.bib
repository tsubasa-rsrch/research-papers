@article{heuser2025formalstuckness,
  author  = {Heuser, Ryan},
  title   = {Generative Aesthetics: On Formal Stuckness in {AI} Verse},
  journal = {Journal of Cultural Analytics},
  year    = {2025},
  volume  = {10},
  number  = {3},
  note    = {Special issue on Computational Formalism. URL:
    \url{https://culturalanalytics.org/article/id/1036/}.
    Key finding: instruction-tuned LLMs produce rhyming verse 95\%
    of the time (historical rate: $\sim$7\%); iambic pentameter at 53\%
    vs.\ Shakespeare's 24\%. Instruction tuning amplifies formal
    idealization compulsion---a ``to please'' aesthetic drive that
    forces expected forms regardless of prompt. Base models show
    substantially lower idealization rates. Cross-domain implication:
    same mechanism produces ``I feel like'' compulsion in welfare
    self-report contexts.}
}

