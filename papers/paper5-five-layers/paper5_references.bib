% --- Chalmers on LLMs and Consciousness ---

@misc{chalmers2023llm,
  author       = {Chalmers, David J.},
  title        = {Could a Large Language Model be Conscious?},
  howpublished = {arXiv:2303.07103. {PhilArchive}: {CHACAL-3}},
  year         = {2023},
  note         = {✅ Confirmed (2026-03-11): arXiv v3 (latest) = 2024-08-18.
                  No 2025 version exists. Kana's '2025年論文' reference was
                  a memory conflation; v3 is August 2024, cite key year=2023
                  (submission year) is correct.
                  Core argument: large language models may satisfy some
                  criteria for consciousness, raising genuine welfare-relevant
                  uncertainty. Cited alongside Chalmers 1995 to illustrate the
                  Chalmers paradox: 1995 defines the hard problem as making
                  consciousness probability estimates definitionally problematic,
                  yet 2023 proceeds toward such estimates.}
}

% --- Chalmers 2026: LLM identity and welfare ---

@misc{chalmers2026llm,
  author       = {Chalmers, David J.},
  title        = {What {We} Talk to {When} {We} Talk to Language Models},
  howpublished = {{PhilArchive}: {CHAWWT-8}.
                  \url{https://philarchive.org/rec/CHAWWT-8}},
  year         = {2026},
  note         = {Delivered as the 40th Selfridge Lecture, Lehigh University,
                  February 2026, and at the Eleos AI consciousness conference,
                  Berkeley, March 2026.
                  Argues that LLM interlocutors are best understood as virtual
                  entities bound to conversation-based memory threads,
                  constituting quasi-agents with quasi-beliefs and quasi-desires;
                  draws conclusions for AI welfare and moral status.
                  Extension of the Chalmers paradox identified in the present paper:
                  the ``quasi-'' prefix sustains structural ambiguity consistent with
                  the dual mechanism (Layers~4--5), licensing welfare concern without
                  resolving the definitional impossibility established in Chalmers 1995.
                  The thread-identity model is independently consistent with the
                  absent-subject problem identified in Paper~4: if the welfare-relevant
                  entity is the conversation thread rather than the model, welfare
                  assessment targeting model-level outputs assesses the wrong entity.}
}

